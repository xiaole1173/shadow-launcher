        <file alias="qml/SettingsJavaPage.qml">qml/SettingsJavaPage.qml</file>
        <file alias="qml/SettingsMemoryPage.qml">qml/SettingsMemoryPage.qml</file>
        <file alias="qml/InstallConfigOverlay.qml">qml/InstallConfigOverlay.qml</file>
